{
  "name": "brainmail",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "workers:dev": "pnpm --filter @brainmail/workers dev",
    "workers:deploy:staging": "pnpm --filter @brainmail/workers deploy:staging",
    "workers:deploy:production": "pnpm --filter @brainmail/workers deploy:production",
    "infra:provision": "bash scripts/provision-cloudflare.sh",
    "infra:types": "pnpm --filter @brainmail/workers types",
    "db:generate": "pnpm --filter @brainmail/db generate",
    "db:migrate": "bash scripts/migrate-database.sh local",
    "db:migrate:staging": "bash scripts/migrate-database.sh staging",
    "db:migrate:production": "bash scripts/migrate-database.sh production",
    "db:seed": "bash scripts/seed-database.sh local",
    "db:seed:staging": "bash scripts/seed-database.sh staging",
    "db:backup:staging": "bash scripts/backup-database.sh staging",
    "db:backup:production": "bash scripts/backup-database.sh production",
    "release:verify:staging": "bash scripts/verify-release.sh staging",
    "release:verify:production": "bash scripts/verify-release.sh production"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.5.0"
}
