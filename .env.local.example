# Next.js local environment
API_URL=http://localhost:8787

# Google OAuth (Phase 3)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/v1/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Worker secrets (copy to workers/.dev.vars)
# SESSION_SECRET=replace-with-long-random-string
# TOKEN_ENCRYPTION_KEY=replace-with-long-random-string
