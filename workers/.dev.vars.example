# Copy to .dev.vars for local worker development.
# Do not commit real secrets.

APP_URL=http://localhost:3000
GOOGLE_OAUTH_REDIRECT_PATH=/api/v1/auth/google/callback

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session + token encryption
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# Optional Gmail push notifications (Google Cloud Pub/Sub topic)
# GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
# GMAIL_WEBHOOK_AUDIENCE=https://your-worker.example.com/api/v1/webhooks/gmail

# Local-only webhook testing when Pub/Sub is not configured
# GMAIL_WEBHOOK_SECRET=generate-a-long-random-secret
